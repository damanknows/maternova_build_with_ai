# ============================================================
#  Maternova — Environment Variables Template
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ============================================================

# --- Supabase (Frontend) ---
VITE_SUPABASE_PROJECT_ID="your-supabase-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"
VITE_SUPABASE_URL="https://your-project.supabase.co"

# --- Gemini (optional, only if using client-side Gemini) ---
VITE_GEMINI_API_KEY=""

# --- AI Backend ---
# Local development: http://localhost:8000
# Production: set this to your Railway / Render deployed backend URL
VITE_API_URL="http://localhost:8000"

# --- Python Backend (read by main.py / ingest.py via python-dotenv) ---
GOOGLE_API_KEY="your-google-gemini-api-key"

# Comma-separated list of allowed frontend origins for CORS
# Production example: "https://maternova.vercel.app,https://www.maternova.vercel.app"
ALLOWED_ORIGINS="http://localhost:8080,http://localhost:5173"
